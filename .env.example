# ============================================
# Medical AI Learning Engine — 환경 변수 명세
# ============================================
# 이 파일을 .env.local 로 복사한 후 실제 값을 입력하세요.
# .env.local 은 절대 git에 커밋하지 않습니다.

# ──────────────────────────────────────────
# Supabase
# ──────────────────────────────────────────
# 프로젝트 URL — Supabase 대시보드 → Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public Anon Key — 브라우저에서 사용 가능 (RLS 정책으로 보호됨)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxx...

# Service Role Key — 서버 사이드 전용, 절대 클라이언트에 노출 금지
SUPABASE_SERVICE_ROLE_KEY=eyJxxxx...

# ──────────────────────────────────────────
# Anthropic (Claude API)
# ──────────────────────────────────────────
# https://console.anthropic.com/ 에서 발급
ANTHROPIC_API_KEY=sk-ant-xxxx...

# 사용할 모델 ID
ANTHROPIC_GEN_MODEL=claude-sonnet-4-6
ANTHROPIC_VERIFY_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_VISION_MODEL=claude-sonnet-4-6

# Anthropic SDK 호출 timeout. 기본 60초.
# 외부 API hang으로 서버 함수가 오래 묶이는 것을 방지합니다.
# SDK 자체 재시도는 끄고 본 코드의 withRetry 한 곳으로 일원화돼 있어,
# 최악 timeout × 재시도 횟수까지 대기할 수 있다는 점만 유의.
ANTHROPIC_TIMEOUT_MS=60000

# ──────────────────────────────────────────
# Voyage AI (Embeddings — Anthropic 권장)
# ──────────────────────────────────────────
# https://www.voyageai.com/ 에서 발급
VOYAGE_API_KEY=pa-xxxx...
VOYAGE_EMBED_MODEL=voyage-3
VOYAGE_EMBED_DIM=1024

# ──────────────────────────────────────────
# 토스페이먼츠 (Payment)
# ──────────────────────────────────────────
# Phase 2 (M4 Open Beta) 이후 활성화
TOSSPAYMENTS_CLIENT_KEY=test_ck_xxxx...
TOSSPAYMENTS_SECRET_KEY=test_sk_xxxx...
# 토스 webhook 서명 검증용. 누락 시 webhook 라우트는 200 OK 를 반환하지만
# 이벤트는 침묵 무시되고 ops_alerts 에 critical 알림이 남는다.
TOSSPAYMENTS_WEBHOOK_SECRET=whsec_xxxx...

# ──────────────────────────────────────────
# QStash (Upstash) — 업로드 OCR 비동기 큐
# ──────────────────────────────────────────
# 발행 측: 큐로 작업을 던질 때 필요. 둘 중 하나라도 없으면 inline (동기) 모드로
# fallback 돼 큰 파일 OCR 이 호스팅 환경의 function timeout(maxDuration=300)에 걸릴 수 있다.
QSTASH_TOKEN=qstash_xxxx...
QSTASH_TARGET_URL=https://your-host.example.com/api/queue/process-upload

# 수신 측: /api/queue/process-upload 가 서명 검증에 사용.
# production 누락 시 401. 키 로테이션 중에는 둘 모두 채워두면 무중단 교체.
QSTASH_CURRENT_SIGNING_KEY=sig_xxxx...
QSTASH_NEXT_SIGNING_KEY=sig_xxxx...

# ──────────────────────────────────────────
# 애플리케이션 설정
# ──────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# CPX FastAPI service (server-side only). Example: http://127.0.0.1:8787
# Deploy this service on a private network or protected service URL; the browser only calls /api/cpx.
CPX_BACKEND_URL=
# Shared with the CPX FastAPI service. Use a long random value; never expose it to the browser.
CPX_PROXY_SHARED_SECRET=
# Apply supabase/migrations/00022_cpx_sessions.sql first, then enable to store CPX records with RLS.
CPX_PERSIST_TO_SUPABASE=false
NODE_ENV=development

# 콘텐츠 생성 안전장치
MAX_QUESTIONS_PER_REQUEST=50
MAX_UPLOAD_SIZE_MB=500
MAX_DAILY_AI_COST_USD=100

# ──────────────────────────────────────────
# 개발 / 특정 기능 안정성 (production 필수 아님)
# ──────────────────────────────────────────
# 로컬 개발에서만 사용. production 에는 절대 설정하지 말 것 —
# 켜져 있으면 webhook / QStash 서명 검증이 우회된다.
ALLOW_UNSIGNED_TOSS_WEBHOOK=
ALLOW_UNSIGNED_QSTASH=

# PPT → 이미지 렌더링용 LibreOffice 바이너리 경로.
# 미설정 시 'soffice' 를 PATH 에서 찾는다.
LIBREOFFICE_BIN=

# OCR 백엔드 선택: auto | tesseract | claude (기본: auto)
# auto 는 Claude(Haiku Vision) 우선, 실패 시 Tesseract 로 폴백.
# Claude 가 비용이 발생하므로 비용 통제 우선이면 명시적으로 'tesseract' 권장.
OCR_BACKEND=auto

# ──────────────────────────────────────────
# 로깅·모니터링 (선택)
# ──────────────────────────────────────────
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
