GEMINI_API_KEY=
GEMINI_LIVE_MODEL=gemini-3.1-flash-live-preview
LOCK_CONSTRAINTS=true

# LectureLink의 CPX_PROXY_SHARED_SECRET과 반드시 같은 긴 임의 문자열을 사용합니다.
CPX_PROXY_SHARED_SECRET=
REQUIRE_LECTURELINK_AUTH=true

# MVP에서는 임상 검수를 출품 이후로 유예했으므로 false입니다.
CPX_RELEASE_READY_ONLY=false

# 단일 컨테이너의 영속 볼륨을 /data에 연결할 때 사용합니다.
CPX_DB_PATH=/data/cpx.sqlite3
PORT=8787
